  "hexagrams": [
    { "id": 1,  "name_zh": "乾",   "name_pinyin": "Qián",     "name_en": "The Creative",  "binary": 63, "judgment": "元，亨，利，贞。",                  "image": "天行健，君子以自强不息。" },
    { "id": 2,  "name_zh": "坤",   "name_pinyin": "Kūn",      "name_en": "The Receptive", "binary": 0,  "judgment": "元亨，利牝马之贞。君子有攸往，先迷后得主，西南得朋，东北丧朋，安贞吉。", "image": "地势坤，君子以厚德载物。" },
    { "id": 3,  "name_zh": "屯",   "name_pinyin": "Zhūn",     "name_en": "Difficulty at the Beginning",   "binary": 1,  "judgment": "元，亨，利，贞。勿用，有攸往，利建侯。", "image": "云雷屯，君子以经纶。" },
    { "id": 4,  "name_zh": "蒙",   "name_pinyin": "Méng",     "name_en": "Youthful Folly",               "binary": 2,  "judgment": "亨。匪我求童蒙，童蒙求我。",          "image": "山下出泉，蒙，君子以果行育德。" },
    { "id": 5,  "name_zh": "需",   "name_pinyin": "Xū",       "name_en": "Waiting",                      "binary": 3,  "judgment": "有孚，光亨，贞吉，利涉大川。",        "image": "云上于天，需，君子以饮食宴乐。" },
    { "id": 6,  "name_zh": "讼",   "name_pinyin": "Sòng",     "name_en": "Conflict",                     "binary": 4,  "judgment": "有孚，窒。惕中吉。终凶。利见大人，不利涉大川。", "image": "天与水违行，讼，君子以作事谋始。" },
    { "id": 7,  "name_zh": "师",   "name_pinyin": "Shī",      "name_en": "The Army",                     "binary": 5,  "judgment": "贞，丈人吉，无咎。",                  "image": "地中有水，师，君子以容民畜众。" },
    { "id": 8,  "name_zh": "比",   "name_pinyin": "Bǐ",       "name_en": "Holding Together",             "binary": 6,  "judgment": "吉。原筮，元永贞，无咎。",            "image": "地上有水，比，先王以建万国，亲诸侯。" },
    { "id": 9,  "name_zh": "小畜", "name_pinyin": "Xiǎo Xù",  "name_en": "Small Taming",                 "binary": 7,  "judgment": "亨。密云不雨，自我西郊。",            "image": "风行天上，小畜，君子以懿文德。" },
    { "id": 10, "name_zh": "履",   "name_pinyin": "Lǚ",       "name_en": "Treading",                     "binary": 8,  "judgment": "履虎尾，不咥人，亨。",                "image": "上天下泽，履，君子以辩上下，定民志。" },
    { "id": 11, "name_zh": "泰",   "name_pinyin": "Tài",      "name_en": "Peace",                        "binary": 9,  "judgment": "小往大来，吉亨。",                    "image": "天地交，泰，后以财成天地之道，辅相天地之宜。" },
    { "id": 12, "name_zh": "否",   "name_pinyin": "Pǐ",       "name_en": "Standstill",                   "binary": 10, "judgment": "否之匪人，不利君子贞，大往小来。",    "image": "天地不交，否，君子以俭德辟难，不可荣以禄。" },
    { "id": 13, "name_zh": "同人", "name_pinyin": "Tóng Rén", "name_en": "Fellowship with Men",          "binary": 11, "judgment": "同人于野，亨。利涉大川，利君子贞。",  "image": "天火同人，君子以类族辨物。" },
    { "id": 14, "name_zh": "大有", "name_pinyin": "Dà Yǒu",   "name_en": "Great Possession",             "binary": 12, "judgment": "元，亨。",                            "image": "火在天上，大有，君子以遏恶扬善，顺天休命。" },
    { "id": 15, "name_zh": "谦",   "name_pinyin": "Qiān",     "name_en": "Modesty",                      "binary": 13, "judgment": "亨，君子有终。",                      "image": "地中有山，谦，君子以裒多益寡，称物平施。" },
    { "id": 16, "name_zh": "豫",   "name_pinyin": "Yù",       "name_en": "Enthusiasm",                   "binary": 14, "judgment": "利建侯行师。",                        "image": "雷出地奋，豫，先王以作乐崇德，殷荐之上帝。" },
    { "id": 17, "name_zh": "随",   "name_pinyin": "Suí",      "name_en": "Following",                    "binary": 15, "judgment": "元，亨，利，贞。无咎。",              "image": "泽中有雷，随，君子以向晦入宴息。" },
    { "id": 18, "name_zh": "蛊",   "name_pinyin": "Gǔ",       "name_en": "Work on the Decayed",          "binary": 16, "judgment": "元，亨，利涉大川。先甲三日，后甲三日。", "image": "山下有风，蛊，君子以振民育德。" },
    { "id": 19, "name_zh": "临",   "name_pinyin": "Lín",      "name_en": "Approach",                     "binary": 17, "judgment": "元，亨，利，贞。至于八月有凶。",      "image": "泽上有地，临，君子以教思无穷，容保民无疆。" },
    { "id": 20, "name_zh": "观",   "name_pinyin": "Guān",     "name_en": "Contemplation",                "binary": 18, "judgment": "盥而不荐，有孚颙若。",                "image": "风行地上，观，先王以省方观民设教。" },
    { "id": 21, "name_zh": "噬嗑", "name_pinyin": "Shì Kè",   "name_en": "Biting Through",               "binary": 19, "judgment": "亨，利用狱。",                        "image": "雷电，噬嗑，先王以明罚敕法。" },
    { "id": 22, "name_zh": "贲",   "name_pinyin": "Bì",       "name_en": "Grace",                        "binary": 20, "judgment": "亨。小利有所往。",                    "image": "山下有火，贲，君子以明庶政，无敢折狱。" },
    { "id": 23, "name_zh": "剥",   "name_pinyin": "Bō",       "name_en": "Splitting Apart",              "binary": 21, "judgment": "不利有攸往。",                        "image": "山附于地，剥，上以厚下安宅。" },
    { "id": 24, "name_zh": "复",   "name_pinyin": "Fù",       "name_en": "Return",                       "binary": 22, "judgment": "亨。出入无疾，朋来无咎。反复其道，七日来复，利有攸往。", "image": "雷在地中，复，先王以至日闭关，商旅不行，后不省方。" },
    { "id": 25, "name_zh": "无妄", "name_pinyin": "Wú Wàng",  "name_en": "Innocence",                    "binary": 23, "judgment": "元，亨，利，贞。其匪正有眚，不利有攸往。", "image": "天下雷行，物与无妄，先王以茂对时育万物。" },
    { "id": 26, "name_zh": "大畜", "name_pinyin": "Dà Xù",    "name_en": "Great Taming",                 "binary": 24, "judgment": "利贞，不家食吉，利涉大川。",          "image": "天在山中，大畜，君子以多识前言往行，以畜其德。" },
    { "id": 27, "name_zh": "颐",   "name_pinyin": "Yí",       "name_en": "Mouth Corners",                "binary": 25, "judgment": "贞吉。观颐，自求口实。",              "image": "山下有雷，颐，君子以慎言语，节饮食。" },
    { "id": 28, "name_zh": "大过", "name_pinyin": "Dà Guò",   "name_en": "Great Exceeding",              "binary": 26, "judgment": "栋桡，利有攸往，亨。",                "image": "泽灭木，大过，君子以独立不惧，遁世无闷。" },
    { "id": 29, "name_zh": "坎",   "name_pinyin": "Kǎn",      "name_en": "The Abysmal Water",            "binary": 27, "judgment": "习坎，有孚，维心亨，行有尚。",        "image": "水洊至，习坎，君子以常德行，习教事。" },
    { "id": 30, "name_zh": "离",   "name_pinyin": "Lí",       "name_en": "The Clinging Fire",            "binary": 28, "judgment": "利贞，亨。畜牝牛，吉。",              "image": "明两作，离，大人以继明照于四方。" },
    { "id": 31, "name_zh": "咸",   "name_pinyin": "Xián",     "name_en": "Influence",                    "binary": 29, "judgment": "亨，利贞，取女吉。",                  "image": "泽上有山，咸，君子以虚受人。" },
    { "id": 32, "name_zh": "恒",   "name_pinyin": "Héng",     "name_en": "Duration",                     "binary": 30, "judgment": "亨，无咎，利贞。利有攸往。",          "image": "雷风，恒，君子以立不易方。" },
    { "id": 33, "name_zh": "遁",   "name_pinyin": "Dùn",      "name_en": "Retreat",                      "binary": 31, "judgment": "亨，小利贞。",                        "image": "天下有山，遁，君子以远小人，不恶而严。" },
    { "id": 34, "name_zh": "大壮", "name_pinyin": "Dà Zhuàng","name_en": "Great Power",                  "binary": 32, "judgment": "利贞。",                              "image": "雷在天上，大壮，君子以非礼弗履。" },
    { "id": 35, "name_zh": "晋",   "name_pinyin": "Jìn",      "name_en": "Progress",                     "binary": 33, "judgment": "康侯用锡马蕃庶，昼日三接。",          "image": "明出地上，晋，君子以自昭明德。" },
    { "id": 36, "name_zh": "明夷", "name_pinyin": "Míng Yí",  "name_en": "Darkening of the Light",       "binary": 34, "judgment": "利艰贞。",                            "image": "明入地中，明夷，君子以莅众，用晦而明。" },
    { "id": 37, "name_zh": "家人", "name_pinyin": "Jiā Rén",  "name_en": "The Family",                   "binary": 35, "judgment": "利女贞。",                            "image": "风火，家人，君子以言有物，而行有恒。" },
    { "id": 38, "name_zh": "睽",   "name_pinyin": "Kuí",      "name_en": "Opposition",                   "binary": 36, "judgment": "小事吉。",                            "image": "上火下泽，睽，君子以同而异。" },
    { "id": 39, "name_zh": "蹇",   "name_pinyin": "Jiǎn",     "name_en": "Obstruction",                  "binary": 37, "judgment": "利西南，不利东北。利见大人。",        "image": "水山蹇，君子以反身修德。" },
    { "id": 40, "name_zh": "解",   "name_pinyin": "Xiè",      "name_en": "Deliverance",                  "binary": 38, "judgment": "利西南。无所往，其来复吉。",          "image": "雷雨作，解，君子以赦过宥罪。" },
    { "id": 41, "name_zh": "损",   "name_pinyin": "Sǔn",      "name_en": "Decrease",                     "binary": 39, "judgment": "有孚，元吉，无咎。可贞。",            "image": "山下有泽，损，君子以惩忿窒欲。" },
    { "id": 42, "name_zh": "益",   "name_pinyin": "Yì",       "name_en": "Increase",                     "binary": 40, "judgment": "利有攸往，利涉大川。",                "image": "风雷，益，君子以见善则迁，有过则改。" },
    { "id": 43, "name_zh": "夬",   "name_pinyin": "Guài",     "name_en": "Breakthrough",                 "binary": 41, "judgment": "扬于王庭，孚号有厉。告自邑，不利即戎。利有攸往。", "image": "泽上于天，夬，君子以施禄及下，居德则忌。" },
    { "id": 44, "name_zh": "姤",   "name_pinyin": "Gòu",      "name_en": "Coming to Meet",               "binary": 42, "judgment": "女壮，勿用取女。",                    "image": "天风姤，后以施命诰四方。" },
    { "id": 45, "name_zh": "萃",   "name_pinyin": "Cuì",      "name_en": "Gathering Together",           "binary": 43, "judgment": "亨。王假有庙，利见大人，亨，利贞。用大牲吉，利有攸往。", "image": "泽上于地，萃，君子以除戎器，戒不虞。" },
    { "id": 46, "name_zh": "升",   "name_pinyin": "Shēng",    "name_en": "Pushing Upward",               "binary": 44, "judgment": "元亨，用见大人，勿恤，南征吉。",      "image": "地中生木，升，君子以顺德，积小以高大。" },
    { "id": 47, "name_zh": "困",   "name_pinyin": "Kùn",      "name_en": "Oppression",                   "binary": 45, "judgment": "亨，贞，大人吉，无咎。有言不信。",    "image": "泽无水，困，君子以致命遂志。" },
    { "id": 48, "name_zh": "井",   "name_pinyin": "Jǐng",     "name_en": "The Well",                     "binary": 46, "judgment": "改邑不改井，无丧无得。",              "image": "木上有水，井，君子以劳民劝相。" },
    { "id": 49, "name_zh": "革",   "name_pinyin": "Gé",       "name_en": "Revolution",                   "binary": 47, "judgment": "己日乃孚，元亨利贞，悔亡。",          "image": "泽中有火，革，君子以治历明时。" },
    { "id": 50, "name_zh": "鼎",   "name_pinyin": "Dǐng",     "name_en": "The Cauldron",                 "binary": 48, "judgment": "元吉，亨。",                          "image": "木上有火，鼎，君子以正位凝命。" },
    { "id": 51, "name_zh": "震",   "name_pinyin": "Zhèn",     "name_en": "The Arousing Thunder",         "binary": 49, "judgment": "亨。震来虩虩，笑言哑哑。震惊百里，不丧匕鬯。", "image": "洊雷，震，君子以恐惧修省。" },
    { "id": 52, "name_zh": "艮",   "name_pinyin": "Gèn",      "name_en": "Keeping Still Mountain",       "binary": 50, "judgment": "艮其背，不获其身，行其庭，不见其人，无咎。", "image": "兼山，艮，君子以思不出其位。" },
    { "id": 53, "name_zh": "渐",   "name_pinyin": "Jiàn",     "name_en": "Development",                  "binary": 51, "judgment": "女归吉，利贞。",                      "image": "山上有木，渐，君子以居贤德，善俗。" },
    { "id": 54, "name_zh": "归妹", "name_pinyin": "Guī Mèi",  "name_en": "The Marrying Maiden",          "binary": 52, "judgment": "征凶，无攸利。",                      "image": "泽上有雷，归妹，君子以永终知敝。" },
    { "id": 55, "name_zh": "丰",   "name_pinyin": "Fēng",     "name_en": "Abundance",                    "binary": 53, "judgment": "亨。王假之，勿忧，宜日中。",          "image": "雷电皆至，丰，君子以折狱致刑。" },
    { "id": 56, "name_zh": "旅",   "name_pinyin": "Lǚ",       "name_en": "The Wanderer",                 "binary": 54, "judgment": "小亨，旅贞吉。",                      "image": "山上有火，旅，君子以明慎用刑，而不留狱。" },
    { "id": 57, "name_zh": "巽",   "name_pinyin": "Xùn",      "name_en": "The Gentle Wind",              "binary": 55, "judgment": "小亨，利有攸往，利见大人。",          "image": "随风，巽，君子以申命行事。" },
    { "id": 58, "name_zh": "兑",   "name_pinyin": "Duì",      "name_en": "The Joyous Lake",              "binary": 56, "judgment": "亨，利贞。",                          "image": "丽泽，兑，君子以朋友讲习。" },
    { "id": 59, "name_zh": "涣",   "name_pinyin": "Huàn",     "name_en": "Dispersion",                   "binary": 57, "judgment": "亨。王假有庙，利涉大川，利贞。",      "image": "风行水上，涣，先王以享于帝立庙。" },
    { "id": 60, "name_zh": "节",   "name_pinyin": "Jié",      "name_en": "Limitation",                   "binary": 58, "judgment": "亨，苦节不可贞。",                    "image": "泽上有水，节，君子以制数度，议德行。" },
    { "id": 61, "name_zh": "中孚", "name_pinyin": "Zhōng Fú", "name_en": "Inner Truth",                  "binary": 59, "judgment": "豚鱼吉，利涉大川，利贞。",            "image": "泽上有风，中孚，君子以议狱缓死。" },
    { "id": 62, "name_zh": "小过", "name_pinyin": "Xiǎo Guò", "name_en": "Small Exceeding",              "binary": 60, "judgment": "亨，利贞。可小事，不可大事。",        "image": "山上有雷，小过，君子以行过乎恭，丧过乎哀，用过乎俭。" },
    { "id": 63, "name_zh": "既济", "name_pinyin": "Jì Jì",    "name_en": "After Completion",             "binary": 61, "judgment": "亨，小利贞。初吉终乱。",              "image": "水在火上，既济，君子以思患而豫防之。" },
    { "id": 64, "name_zh": "未济", "name_pinyin": "Wèi Jì",   "name_en": "Before Completion",            "binary": 62, "judgment": "亨。小狐汔济，濡其尾，无攸利。",      "image": "火在水上，未济，君子以慎辨物居方。" }
